{
  "$schema": "https://raw.githubusercontent.com/nicedayto/tauri-docs/refs/heads/dev/src/content/docs/reference/2.0.0/config.schema.json",
  "productName": "Pulse",
  "version": "0.1.0",
  "identifier": "com.pulse.desktop",
  "build": {
    "beforeDevCommand": "cd src && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd src && npm run build",
    "frontendDist": "../src/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pulse",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
